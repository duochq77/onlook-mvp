const API_BASE = process.env.NEXT_PUBLIC_API_BASE || '/api'

export async function getToken({
  room,
  identity,
  role,
}: {
  room: string
  identity: string
  role: 'publisher' | 'subscriber'
}): Promise<string | null> {
  try {
    const res = await fetch(`${API_BASE}/token?room=${room}&identity=${identity}&role=${role}`)
    const data = await res.json()
    return data.token || null
  } catch (err) {
    console.error('❌ Lỗi gọi API getToken:', err)
    return null
  }
}
