{
  "builds": [
    { "src": "api/token.ts", "use": "@vercel/node" },
    { "src": "public/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/token", "dest": "api/token.ts" },
    { "src": "/(viewer|seller)/(.*)", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
