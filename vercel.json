{
  "builds": [
    { "src": "api/*.ts", "use": "@vercel/node" },
    { "src": "public/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/token", "dest": "api/token.ts" },
    { "src": "/api/startLivestream", "dest": "api/startLivestream.ts" },
    { "src": "/api/endLivestream", "dest": "api/endLivestream.ts" },
    { "src": "/(viewer|seller)/.*", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
